VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key-here

# n8n-Mailversand (Belege + Bilder gehen an diesen Webhook).
# Hinweis: VITE_-Werte landen sichtbar im Browser-Bundle — der Secret-Header ist
# nur eine schwache Hürde, kein echtes Geheimnis (interne App, bewusst akzeptiert).
VITE_N8N_MAIL_WEBHOOK_URL=https://your-n8n-host/webhook/warmme-mail
VITE_N8N_MAIL_WEBHOOK_SECRET=your-webhook-token-here
